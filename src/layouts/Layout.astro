---
import "../styles/global.css";

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title,
  description,
  canonical = Astro.url.href,
  ogImage = "/og-default.jpg",
} = Astro.props;

const siteName = "BeautyHealth";
---

<!doctype html>
<html lang="ro">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-HS59YL4Y3D"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', 'G-HS59YL4Y3D');
    </script>

    <slot name="head" />
  </head>
  <body>
    <slot />

    <script is:inline>
      // bh_affiliate_click - delegare globala, functioneaza atat pentru cardurile
      // randate de Astro (paginare normala) cat si pentru cele injectate de JS
      // (rezultate cautare), pentru ca ambele au aceleasi data-attributes.
      document.addEventListener('click', function (e) {
        var card = e.target.closest('.product-card');
        if (!card) return;
        if (typeof gtag !== 'function') return;
        gtag('event', 'bh_affiliate_click', {
          product_id: card.dataset.productId || '',
          product_title: card.dataset.productTitle || '',
          product_price: card.dataset.productPrice || '',
          page_location: window.location.href,
        });
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --navy: #0B1F4A;
    --gold: #C89B3C;
    --bg: #FAF8F5;
    --text: #1A1A1A;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    font-family: 'Segoe UI', system-ui, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.5;
  }
  a { color: var(--navy); }
  img { max-width: 100%; display: block; }
</style>
